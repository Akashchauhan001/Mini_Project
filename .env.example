# ARID Platform Environment Variables
# Copy this file to .env and fill in your values

# ── Optional: OpenAI (for advanced AI responses) ──────────────
# If not set, the assistant uses a rule-based fallback
OPENAI_API_KEY=

# ── Neo4j (skip if using in-memory graph) ────────────────────
# Set NEO4J_AVAILABLE=true only if Neo4j is running
NEO4J_AVAILABLE=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── Flask ─────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production

# ── AI Models ─────────────────────────────────────────────────
# Sentence Transformers model for FAISS (auto-downloaded on first run)
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
